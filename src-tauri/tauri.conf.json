{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Dark Mode",
  "version": "1.0.5",
  "identifier": "com.isjeffcom.winautodarkmode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auto Dark Mode",
        "width": 720,
        "height": 520,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Jeff @ Soda Game Studio",
    "targets": ["nsis"],
    "icon": ["icons/Tray_Icon.ico"],
    "resources": ["icons/*.ico"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/Tray_Icon.ico",
        "sidebarImage": "../nsis_sideimg.bmp"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
