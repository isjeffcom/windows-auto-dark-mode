{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Dark Mode",
  "version": "1.0.8",
  "identifier": "com.isjeffcom.winautodarkmode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Auto Dark Mode",
        "width": 730,
        "height": 530,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Jeff @ Soda Game Studio",
    "targets": ["nsis"],
    "icon": ["../resources/Tray_Icon_512.ico"],
    "resources": ["icons/*.ico", "../resources/Tray_Icon_512.ico"],
    "windows": {
      "nsis": {
        "installerIcon": "../resources/Tray_Icon_512.ico",
        "sidebarImage": "../nsis_sideimg.bmp"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
